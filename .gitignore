# Flutter and Dart: build outputs, tooling, and generated files
# Based on common Flutter/Dart templates; tailored for apps.

# ---- Build outputs ------------------------------------------------------
# Flutter build directory
build/

# Gradle build cache
.gradle/

# ---- Dart tooling & caches ----------------------------------------------
.dart_tool/
.pub/
.pub-cache/
.packages

# Flutter/Dart generated and tooling files
.flutter-plugins
.flutter-plugins-dependencies
flutter_export_environment.sh
generated_plugin_registrant.dart

# ---- IDEs and editors ---------------------------------------------------
.idea/
*.iml
.vscode/

# macOS Finder
.DS_Store

# Windows
Thumbs.db

# Logs and temp files
*.log
*.tmp

# ---- Android -----------------------------------------------------------
android/.gradle/
android/local.properties
android/app/*.iml

# Don't commit local Android keystore files
*.jks

# ---- iOS / Xcode ------------------------------------------------------
ios/Pods/
ios/Podfile.lock
ios/.symlinks/
ios/Flutter/Flutter.framework
ios/Flutter/Engine.xcframework
ios/Flutter/Generated.xcconfig
ios/Runner.xcworkspace/
*.xcworkspace
xcuserdata/
DerivedData/
*.moved-aside
*.xcuserstate

# ---- Flutter web -------------------------------------------------------
/.dart_tool/build/

# ---- Generated files and artifacts -------------------------------------
**/build/
**/generated/**
lib/generated_plugin_registrant.dart

# ---- Sensitive or local config -----------------------------------------
.env
*.env
google-services.json
GoogleService-Info.plist

# ---- Tests / Misc ------------------------------------------------------
.test_output/

# End of .gitignore
